# SQLite (default, easiest for local dev)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="change-this-to-a-random-secret-string"
NEXTAUTH_URL="http://localhost:3000"

# ==========================================================
# DEPLOY KE VERCEL:
# SQLite TIDAK cocok untuk Vercel (filesystem serverless bersifat
# read-only / sementara). Untuk produksi, gunakan database
# PostgreSQL (mis. Vercel Postgres, Neon, atau Supabase) lalu:
# 1. Ganti provider di prisma/schema.prisma menjadi "postgresql"
# 2. Isi DATABASE_URL dengan connection string Postgres
# 3. Jalankan: npx prisma migrate deploy
# Lihat README.md bagian "Deploy ke Vercel" untuk detail lengkap.
# ==========================================================
